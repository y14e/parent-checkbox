{
  "name": "@y14e/parent-checkbox",
  "version": "1.0.7",
  "description": "WAI-ARIA compliant checkbox (mixed) pattern implementation in TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "checkbox",
    "checkboxes",
    "component",
    "typescript",
    "utility"
  ],
  "author": "Yusuke Kamiyamane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y14e/parent-checkbox.git"
  },
  "bugs": {
    "url": "https://github.com/y14e/parent-checkbox/issues"
  },
  "homepage": "https://github.com/y14e/parent-checkbox#readme",
  "devDependencies": {
    "bun-types": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
